# syntax=docker/dockerfile:1.7

FROM node:22-alpine AS builder
WORKDIR /app

ENV NODE_ENV=development

COPY package*.json ./
RUN --mount=type=cache,target=/root/.npm \
    if [ -f package-lock.json ]; then \
        npm ci; \
    else \
        npm install; \
    fi

COPY . .
RUN --mount=type=cache,target=/root/.npm \
    if node -e "process.exit(require('./package.json').scripts?.build ? 0 : 1)"; then \
        npm run build; \
    fi; \
    sh hono_gen.sh

# Prune dev dependencies in a separate stage so that the builder stage (used
# as the dev mode environment) keeps them available
FROM builder AS pruned
RUN npm prune --omit=dev

FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOST=0.0.0.0
ENV HOSTNAME=0.0.0.0

RUN apk add --no-cache tini

COPY --from=pruned --chown=node:node /app /app
COPY --chown=node:node hono_start.sh /usr/local/bin/hono_start.sh
RUN chmod +x /usr/local/bin/hono_start.sh

USER node

EXPOSE 3000

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["hono_start.sh"]
